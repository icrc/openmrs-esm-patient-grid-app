  "description": "The microfrontend module providing the patient grid feature.",
  "browser": "dist/openmrs-esm-patient-grid-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "webpack serve --mode=development",
